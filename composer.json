{
    "name": "wilsonatb/in-app-purchases",
    "description": "Cross-platform in-app purchases for NativePHP Mobile (Google Play Billing + StoreKit 2)",
    "type": "nativephp-plugin",
    "license": "MIT",
    "authors": [
        {
            "name": "Wilsonatb",
            "email": "wilsonatb@users.noreply.github.com"
        }
    ],
    "require": {
        "php": "^8.2",
        "nativephp/mobile": "^3.0"
    },
    "require-dev": {
        "pestphp/pest": "^3.0"
    },
    "autoload": {
        "psr-4": {
            "Wilsonatb\\InAppPurchases\\": "src/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Wilsonatb\\InAppPurchases\\InAppPurchasesServiceProvider"
            ]
        },
        "nativephp": {
            "manifest": "nativephp.json"
        }
    },
    "scripts": {
        "test": "pest"
    },
    "config": {
        "allow-plugins": {
            "pestphp/pest-plugin": true
        }
    }
}
